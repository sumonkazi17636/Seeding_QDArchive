{"SurveyEntry":{"SurveyID":"SV_9vOBPl5nRAYhReR","SurveyName":"IASGE-FollowUpInterview","SurveyDescription":null,"SurveyOwnerID":"UR_e4zQHSBJPkkLdeR","SurveyBrandID":"nyu","DivisionID":null,"SurveyLanguage":"EN","SurveyActiveResponseSet":"RS_diOmDlfXJVLpVC5","SurveyStatus":"Active","SurveyStartDate":"0000-00-00 00:00:00","SurveyExpirationDate":"0000-00-00 00:00:00","SurveyCreationDate":"2020-01-07 10:30:43","CreatorID":"UR_e4zQHSBJPkkLdeR","LastModified":"2020-07-07 16:20:02","LastAccessed":"0000-00-00 00:00:00","LastActivated":"2020-01-07 10:33:48","Deleted":null},"SurveyElements":[{"SurveyID":"SV_9vOBPl5nRAYhReR","Element":"BL","PrimaryAttribute":"Survey Blocks","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":[{"Type":"Default","Description":"Default Question Block","ID":"BL_0Ajj2C6hZh3fMP3","BlockElements":[{"Type":"Question","QuestionID":"QID1"},{"Type":"Question","QuestionID":"QID5","SkipLogic":[{"SkipLogicID":1,"ChoiceLocator":"q:\/\/QID5\/SelectableChoice\/5","Condition":"Selected","SkipToDestination":"ENDOFSURVEY","Locator":"q:\/\/QID5\/SelectableChoice\/5","SkipToDescription":"<p>Informed Consent for Inv... <strong>I do not wish to participat...<\/strong>  <strong>Is Selected<\/strong>","Description":"Condition: <strong title=\"I do not wish to participate in the interview.\">I do not wish to participat...<\/strong> <strong>Is Selected<\/strong>. Skip To: <strong>End of Survey<\/strong>.","QuestionID":"QID5"}]},{"Type":"Question","QuestionID":"QID2"},{"Type":"Question","QuestionID":"QID3"},{"Type":"Question","QuestionID":"QID4"}]},{"Type":"Trash","Description":"Trash \/ Unused Questions","ID":"BL_6YfIY4pHE7po2kB"}]},{"SurveyID":"SV_9vOBPl5nRAYhReR","Element":"FL","PrimaryAttribute":"Survey Flow","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"Type":"Root","FlowID":"FL_1","Flow":[{"Type":"Block","ID":"BL_0Ajj2C6hZh3fMP3","FlowID":"FL_2"}],"Properties":{"Count":2,"RemovedFieldsets":[]}}},{"SurveyID":"SV_9vOBPl5nRAYhReR","Element":"RS","PrimaryAttribute":"RS_diOmDlfXJVLpVC5","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":null},{"SurveyID":"SV_9vOBPl5nRAYhReR","Element":"SO","PrimaryAttribute":"Survey Options","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"BackButton":"false","SaveAndContinue":"false","SurveyProtection":"PublicSurvey","BallotBoxStuffingPrevention":"true","NoIndex":"Yes","SecureResponseFiles":"true","SurveyExpiration":null,"SurveyTermination":"DisplayMessage","Header":"<span style=\"font-size:19px;\">Investigating &amp; Archiving the Scholarly Git Experience<\/span> <!-- -- JS libraries for predictive text questions ----><link href=\"https:\/\/ajax.googleapis.com\/ajax\/libs\/jqueryui\/1.12.1\/themes\/smoothness\/jquery-ui.css\" rel=\"stylesheet\" \/> <script src=\"https:\/\/ajax.googleapis.com\/ajax\/libs\/jqueryui\/1.12.1\/jquery-ui.min.js\"><\/script><link href=\"https:\/\/cdnjs.cloudflare.com\/ajax\/libs\/select2\/4.0.6-rc.0\/css\/select2.min.css\" rel=\"stylesheet\" \/> <script src=\"https:\/\/cdnjs.cloudflare.com\/ajax\/libs\/select2\/4.0.6-rc.0\/js\/select2.min.js\"><\/script>","Footer":"","ProgressBarDisplay":"Text","PartialData":"+1 week","ValidationMessage":null,"PreviousButton":" \u2190 Back","NextButton":"Next \u2192 ","SkinLibrary":"nyu","SkinType":"templated","Skin":{"brandingId":null,"templateId":"*base","overrides":{"colors":{"secondary":"#070707","primary":"#fff"},"answerText":{"size":"24px"},"font":{"family":"verdana, geneva, sans-serif"},"contrast":1,"logo":{"url":"https:\/\/nyu.qualtrics.com\/CP\/Graphic.php?IM=IM_d6yLa0SqbWjPvdH"}}},"NewScoring":1,"EOSMessage":"MS_5cM61EOTtzVskmN","ShowExportTags":"false","CollectGeoLocation":"false","SurveyTitle":"IASGE Interview","SurveyMetaDescription":"","PasswordProtection":"No","AnonymizeResponse":"Yes","Password":"","RefererCheck":"No","RefererURL":"https:\/\/nyu.qualtrics.com\/jfe\/form\/SV_5ArtYnx6kWMXYNv","EOSMessageLibrary":"UR_e4zQHSBJPkkLdeR","EOSRedirectURL":"https:\/\/","EmailThankYou":"false","ThankYouEmailMessageLibrary":null,"ThankYouEmailMessage":null,"ValidateMessage":"false","ValidationMessageLibrary":null,"InactiveSurvey":"DefaultMessage","InactiveMessageLibrary":"","InactiveMessage":"","AvailableLanguages":{"EN":[]},"ProtectSelectionIds":true,"UseCustomSurveyLinkCompletedMessage":null,"SurveyLinkCompletedMessage":"","SurveyLinkCompletedMessageLibrary":"","ResponseSummary":"No","PartialDataCloseAfter":"LastActivity","ActiveResponseSet":null,"SurveyName":"IASGE-FollowUpInterview","CustomStyles":[]}},{"SurveyID":"SV_9vOBPl5nRAYhReR","Element":"TR","PrimaryAttribute":"TR_bBGi3pCHUOAQgbr","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"TriggerAction":"EmailMessage","Type":"OnQuestionResponse","ToEmail":"${q:\/\/QID3\/ChoiceTextEntryValue}","FromName":"Vicky Steeves - IASGE","FromEmail":"vicky.steeves@nyu.edu","SendDate":"now","Subject":"IASGE Interview Informed Consent","Message":"Hello ${q:\/\/QID2\/ChoiceTextEntryValue},<br \/>\n<br \/>\nThank you so much for being willing to talk with us about your usage of Git and source code hosting platforms!<br \/>\n<br \/>\nBelow is a full report of your answers, including the informed consent for your records.<br \/>\n<br \/>\nBest,<br \/>\nVicky Steeves &amp; Sarah Nguyen<br \/>\n<a href=\"https:\/\/investigating-archiving-git.gitlab.io\/\">Investigating and Archiving the Scholarly Git Experience<\/a>","IncludeReport":true,"UseFullText":true,"ID":"TR_bBGi3pCHUOAQgbr","Logic":{"0":{"0":{"LogicType":"Question","QuestionID":"QID5","QuestionIsInLoop":"no","ChoiceLocator":"q:\/\/QID5\/SelectableChoice\/4","Operator":"Selected","QuestionIDFromLocator":"QID5","LeftOperand":"q:\/\/QID5\/SelectableChoice\/4","Type":"Expression","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"QuestionDesc\">Informed Consent for Investigating and Archiving the Scholarly Git Experience You have been invit...<\/span> <span class=\"LeftOpDesc\">I understand and wish to participate in the interview<\/span> <span class=\"OpDesc\">Is Selected<\/span> "},"Type":"If"},"Type":"BooleanExpression"}}},{"SurveyID":"SV_9vOBPl5nRAYhReR","Element":"SCO","PrimaryAttribute":"Scoring","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"ScoringCategories":[],"ScoringCategoryGroups":[],"ScoringSummaryCategory":null,"ScoringSummaryAfterQuestions":0,"ScoringSummaryAfterSurvey":0,"DefaultScoringCategory":null,"AutoScoringCategory":null}},{"SurveyID":"SV_9vOBPl5nRAYhReR","Element":"PROJ","PrimaryAttribute":"CORE","SecondaryAttribute":null,"TertiaryAttribute":"1.1.0","Payload":{"ProjectCategory":"CORE","SchemaVersion":"1.1.0"}},{"SurveyID":"SV_9vOBPl5nRAYhReR","Element":"STAT","PrimaryAttribute":"Survey Statistics","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"MobileCompatible":true,"ID":"Survey Statistics"}},{"SurveyID":"SV_9vOBPl5nRAYhReR","Element":"QC","PrimaryAttribute":"Survey Question Count","SecondaryAttribute":"5","TertiaryAttribute":null,"Payload":null},{"SurveyID":"SV_9vOBPl5nRAYhReR","Element":"SQ","PrimaryAttribute":"QID3","SecondaryAttribute":"Email Address","TertiaryAttribute":null,"Payload":{"QuestionText":"Email Address","DefaultChoices":false,"DataExportTag":"Q4","QuestionType":"TE","Selector":"SL","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Email Address","Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"ContentType","MinChars":null,"TotalChars":null,"ContentType":"ValidEmail","ValidDateType":"DateWithFormat","ValidPhoneType":"ValidUSPhone","ValidZipType":"ValidUSZip"}},"GradingData":[],"Language":[],"QuestionID":"QID3","QuestionText_Unsafe":"Email Address"}},{"SurveyID":"SV_9vOBPl5nRAYhReR","Element":"SQ","PrimaryAttribute":"QID2","SecondaryAttribute":"Full Name","TertiaryAttribute":null,"Payload":{"QuestionText":"Full Name","DefaultChoices":false,"DataExportTag":"Q3","QuestionType":"TE","Selector":"SL","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Full Name","Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"QuestionID":"QID2","Choices":[],"ChoiceOrder":[],"DataVisibility":{"Private":false,"Hidden":false},"NextChoiceId":1,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionText_Unsafe":"Full Name"}},{"SurveyID":"SV_9vOBPl5nRAYhReR","Element":"SQ","PrimaryAttribute":"QID5","SecondaryAttribute":"Informed Consent for Investigating and Archiving the Scholarly Git Experience You have been invit...","TertiaryAttribute":null,"Payload":{"QuestionText":"<p>Informed Consent for Investigating and Archiving the Scholarly Git Experience<\/p><p><br><\/p><p>You\n have been invited to take part in a research study to learn more about \nthe ways in which academics use Git and Git hosting platforms.&nbsp; This study will be conducted by Vicky Steeves and Sarah Nguyen, New York University Division of Libraries. <br><\/p><p><br><\/p><p>\nThe \nstudy is called Investigating and Archiving the Scholarly Git Experience, and you can see more about the project here: https:\/\/investigating-archiving-git.gitlab.io\/.<br><\/p><p>&nbsp;<\/p>\n\n<p>If you agree to be in this study, you will be asked to participate in a 30-60 minute interview over a videoconferencing software. You may be asked to share your screen and walk through some steps with Git and the source code hosting platform you use the most.<br><\/p><p>&nbsp;<\/p>\n\n<p>You will be audio recorded. You may review these recordings and transcripts after they are completed should you wish.<\/p><br>There \nare no known risks associated with your participation in this research \nbeyond those of everyday life. Although you will receive no direct \nbenefits, this research may help the investigator understand the ways in\n which academics use Git and Git hosting platforms with the hope to \nbetter align tools and teaching for those working in the academy.\n\n<p>&nbsp;<\/p>\n\n<p>Confidentiality\n of your research records will be strictly maintained by assigning code \nnumbers to each participant so that data is never directly linked to \nindividual identity. Information not containing identifiers may be used \nin future research, shared with other researchers, or placed in a data \nrepository without your additional consent.<br><\/p>\n\n<p>&nbsp;<\/p>\n\n<p>Participation\n in this study is voluntary. You may refuse to participate or withdraw \nat any time without penalty. For this focus group, you have the right to\n skip or not answer any questions you prefer not to answer. \nNonparticipation or withdrawal will have no negative effects.<br><\/p>\n\n<p>&nbsp;<\/p>\n\n<p>If\n there is anything about the study or your participation that is unclear\n or that you do not understand, if you have questions or wish to report a\n research-related problem, you may contact Vicky Steeves at \n212-992-6269 or vicky.steeves@nyu.edu.<br><\/p>\n\n<p>&nbsp;<\/p>\n\n<p>For\n questions about your rights as a research participant, you may contact \nthe University Committee on Activities Involving Human Subjects \n(UCAIHS), New York University, 665 Broadway, Suite 804, New York, New \nYork, 10012, at ask.humansubjects@nyu.edu or (212) 998-4808. Please \nreference the study #<strong>IRB-FY2019-3399<\/strong> when contacting the IRB (UCAIHS).<\/p>\n\n<p>&nbsp;<\/p>\n\n<p>You will receive an email with this information after submitting this form.<\/p>","DefaultChoices":false,"DataExportTag":"Q2","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Informed Consent for Investigating and Archiving the Scholarly Git Experience You have been invit...","Choices":{"4":{"Display":"I understand and wish to participate in the interview"},"5":{"Display":"I do not wish to participate in the interview."}},"ChoiceOrder":["4","5"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":7,"NextAnswerId":1,"QuestionID":"QID5","DataVisibility":{"Private":false,"Hidden":false},"QuestionText_Unsafe":"<p>Informed Consent for Investigating and Archiving the Scholarly Git Experience<\/p><p><br><\/p><p>You\n have been invited to take part in a research study to learn more about \nthe ways in which academics use Git and Git hosting platforms.&nbsp; This study will be conducted by Vicky Steeves and Sarah Nguyen, New York University Division of Libraries. <br><\/p><p><br><\/p><p>\nThe \nstudy is called Investigating and Archiving the Scholarly Git Experience, and you can see more about the project here: https:\/\/investigating-archiving-git.gitlab.io\/.<br><\/p><p>&nbsp;<\/p>\n\n<p>If you agree to be in this study, you will be asked to participate in a 30-60 minute interview over a videoconferencing software. You may be asked to share your screen and walk through some steps with Git and the source code hosting platform you use the most.<br><\/p><p>&nbsp;<\/p>\n\n<p>You will be audio recorded. You may review these recordings and transcripts after they are completed should you wish.<\/p><br>There \nare no known risks associated with your participation in this research \nbeyond those of everyday life. Although you will receive no direct \nbenefits, this research may help the investigator understand the ways in\n which academics use Git and Git hosting platforms with the hope to \nbetter align tools and teaching for those working in the academy.\n\n<p>&nbsp;<\/p>\n\n<p>Confidentiality\n of your research records will be strictly maintained by assigning code \nnumbers to each participant so that data is never directly linked to \nindividual identity. Information not containing identifiers may be used \nin future research, shared with other researchers, or placed in a data \nrepository without your additional consent.<br><\/p>\n\n<p>&nbsp;<\/p>\n\n<p>Participation\n in this study is voluntary. You may refuse to participate or withdraw \nat any time without penalty. For this focus group, you have the right to\n skip or not answer any questions you prefer not to answer. \nNonparticipation or withdrawal will have no negative effects.<br><\/p>\n\n<p>&nbsp;<\/p>\n\n<p>If\n there is anything about the study or your participation that is unclear\n or that you do not understand, if you have questions or wish to report a\n research-related problem, you may contact Vicky Steeves at \n212-992-6269 or vicky.steeves@nyu.edu.<br><\/p>\n\n<p>&nbsp;<\/p>\n\n<p>For\n questions about your rights as a research participant, you may contact \nthe University Committee on Activities Involving Human Subjects \n(UCAIHS), New York University, 665 Broadway, Suite 804, New York, New \nYork, 10012, at ask.humansubjects@nyu.edu or (212) 998-4808. Please \nreference the study #PENDING when contacting the IRB (UCAIHS).<\/p>\n\n<p>&nbsp;<\/p>\n\n<p>You will receive an email with this information after submitting this form.<\/p>"}},{"SurveyID":"SV_9vOBPl5nRAYhReR","Element":"SQ","PrimaryAttribute":"QID4","SecondaryAttribute":"Please let us know the next three dates\/times you are available (with your timezone as well pleas...","TertiaryAttribute":null,"Payload":{"QuestionText":"Please let us know the next three dates\/times you are available (with your timezone as well please!).","DefaultChoices":false,"DataExportTag":"Q5","QuestionType":"TE","Selector":"FORM","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please let us know the next three dates\/times you are available (with your timezone as well pleas...","Choices":{"1":{"Display":"Preferred Date 1:","InputHeight":29,"InputWidth":470,"TextEntry":"on"},"2":{"Display":"Preferred Date 2:","InputHeight":29,"InputWidth":470,"TextEntry":"on"},"3":{"Display":"Preferred Date 3:","InputHeight":29,"InputWidth":470,"TextEntry":"on"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":null}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionID":"QID4","QuestionText_Unsafe":"Please let us know the next three dates\/times you are available (with your timezone as well please!)."}},{"SurveyID":"SV_9vOBPl5nRAYhReR","Element":"SQ","PrimaryAttribute":"QID1","SecondaryAttribute":"Thank you for completing this survey, and for your willingness to participate in an interview! We...","TertiaryAttribute":null,"Payload":{"QuestionText":"<p>Thank you for completing this survey, and for your willingness to participate in an interview! We will ask you to fill out the informed consent form below, and then&nbsp; to provide your name, email address, and three dates\/times so that we may contact you to schedule a 30-60 minute online interview in the near future.&nbsp; Your email address cannot be linked to the previous survey, and your answers there will remain anonymous.<br><\/p>","DefaultChoices":false,"DataExportTag":"Q1","QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Thank you for completing this survey, and for your willingness to participate in an interview! We...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"QuestionID":"QID1","DataVisibility":{"Private":false,"Hidden":false},"NextChoiceId":1,"NextAnswerId":1,"QuestionText_Unsafe":"<p>Thank you for completing this survey, and for your willingness to participate in an interview! <\/p><p>Please provide your name, email address, and three dates\/times so that we may contact you to schedule a 30-60 minute online interview in the near future.<\/p><p><br><\/p><p>Your email address cannot be linked to the previous survey, and your answers there will remain anonymous.<br><\/p>"}}]}