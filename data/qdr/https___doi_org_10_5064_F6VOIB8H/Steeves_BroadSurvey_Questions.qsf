ity":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_5ArtYnx6kWMXYNv","Element":"SQ","PrimaryAttribute":"QID22","SecondaryAttribute":"How often do you use\/interact with git?","TertiaryAttribute":null,"Payload":{"QuestionText":"How often do you use\/interact with git?","DataExportTag":"Q24","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"How often do you use\/interact with git?","Choices":{"1":{"Display":"Daily"},"2":{"Display":"Weekly"},"3":{"Display":"Monthly"},"4":{"Display":"Once a semester"},"5":{"Display":"Yearly"},"6":{"Display":"Other","TextEntry":"true"}},"ChoiceOrder":[1,2,3,4,5,6],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":7,"NextAnswerId":1,"QuestionID":"QID22","DataVisibility":{"Private":false,"Hidden":false},"QuestionText_Unsafe":"On a weekly basis, how often do you use\/interact with git?"}},{"SurveyID":"SV_5ArtYnx6kWMXYNv","Element":"SQ","PrimaryAttribute":"QID74","SecondaryAttribute":"How often do you use\/interact with git?","TertiaryAttribute":null,"Payload":{"QuestionText":"How often do you use\/interact with git?","DataExportTag":"Q12","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"How often do you use\/interact with git?","Choices":{"1":{"Display":"Daily"},"2":{"Display":"Once every 4 months"},"3":{"Display":"Weekly"},"6":{"Display":"Other:","TextEntry":"true"},"7":{"Display":"Monthly"},"8":{"Display":"Once a year"}},"ChoiceOrder":["1","3","7","2","8","6"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":9,"NextAnswerId":1,"QuestionID":"QID74","QuestionText_Unsafe":"On a weekly basis, how often do you use\/interact with git?","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_5ArtYnx6kWMXYNv","Element":"SQ","PrimaryAttribute":"QID19","SecondaryAttribute":"How proficient do you think you are with git?","TertiaryAttribute":null,"Payload":{"QuestionText":"How proficient do you think you are with git?","DataExportTag":"Q22","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"How proficient do you think you are with git?","Choices":{"1":{"Display":"1 - Fundamental Awareness (basic knowledge)"},"2":{"Display":"2 - Novice (limited experience)"},"3":{"Display":"3 - Intermediate (practical application)"},"4":{"Display":"4 - Advanced (applied theory)"},"5":{"Display":"5 - Expert (recognized authority)"}},"ChoiceOrder":[1,2,3,4,5],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":6,"NextAnswerId":1,"QuestionID":"QID19","DataVisibility":{"Private":false,"Hidden":false},"QuestionText_Unsafe":"How proficient do you think you are with git?"}},{"SurveyID":"SV_5ArtYnx6kWMXYNv","Element":"SQ","PrimaryAttribute":"QID45","SecondaryAttribute":"If there was a academic-specific user-friendly git hosting platform would you use it?","TertiaryAttribute":null,"Payload":{"QuestionText":"If there was a academic-specific user-friendly git hosting platform would you use it?","DataExportTag":"Q22","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"If there was a academic-specific user-friendly git hosting platform would you use it?","Choices":{"1":{"Display":"Yes"},"2":{"Display":"Maybe"},"3":{"Display":"No"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"OFF","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID45","DataVisibility":{"Private":false,"Hidden":false},"QuestionText_Unsafe":"If there was a academic-specific user-friendly git hosting platform would you use it?"}},{"SurveyID":"SV_5ArtYnx6kWMXYNv","Element":"SQ","PrimaryAttribute":"QID87","SecondaryAttribute":"If there was an academic-specific user-friendly git hosting platform, would you use it?","TertiaryAttribute":null,"Payload":{"QuestionText":"If there was an academic-specific user-friendly git hosting platform, would you use it?","DataExportTag":"Q45","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"If there was an academic-specific user-friendly git hosting platform, would you use it?","Choices":{"1":{"Display":"Yes"},"2":{"Display":"Maybe"},"3":{"Display":"No"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID87","QuestionText_Unsafe":"If there was an academic-specific user-friendly git hosting platform, would you use it?"}},{"SurveyID":"SV_5ArtYnx6kWMXYNv","Element":"SQ","PrimaryAttribute":"QID54","SecondaryAttribute":"If there was an academic-specific, user-friendly git hosting platform, would you use it?","TertiaryAttribute":null,"Payload":{"QuestionText":"If there was an academic-specific, user-friendly git hosting platform, would you use it?","DataExportTag":"Q49","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"If there was an academic-specific, user-friendly git hosting platform, would you use it?","Choices":{"1":{"Display":"Yes"},"2":{"Display":"Maybe"},"3":{"Display":"No"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID54","DataVisibility":{"Private":false,"Hidden":false},"QuestionText_Unsafe":"If there was an academic-specific, user-friendly git hosting platform, would you use it?"}},{"SurveyID":"SV_5ArtYnx6kWMXYNv","Element":"SQ","PrimaryAttribute":"QID30","SecondaryAttribute":"If yes, briefly explain how you have used Continuous Integration (CI).","TertiaryAttribute":null,"Payload":{"QuestionText":"If yes, briefly explain how you have used Continuous Integration (CI).","DefaultChoices":false,"DataExportTag":"Q32","QuestionType":"TE","Selector":"ML","Configuration":{"QuestionDescriptionOption":"UseText","AllowFreeResponse":"false"},"QuestionDescription":"If yes, briefly explain how you have used Continuous Integration (CI).","Validation":{"Settings":{"ForceResponse":"OFF","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID30","DataVisibility":{"Private":false,"Hidden":false},"SearchSource":{"AllowFreeResponse":"false"},"QuestionText_Unsafe":"If yes, briefly explain how you have used Continuous Integration (CI)."}},{"SurveyID":"SV_5ArtYnx6kWMXYNv","Element":"SQ","PrimaryAttribute":"QID34","SecondaryAttribute":"In your institution, what is your role\/status?","TertiaryAttribute":null,"Payload":{"QuestionText":"In your institution, what is your role\/status?","DataExportTag":"Q51","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"In your institution, what is your role\/status?","Choices":{"1":{"Display":"Tenure track faculty"},"2":{"Display":"Continuing-contract\/clinical\/teaching faculty"},"3":{"Display":"Doctoral student"},"4":{"Display":"Other","TextEntry":"true"},"5":{"Display":"Staff"},"6":{"Display":"Postdoc"},"7":{"Display":"Masters student"},"8":{"Display":"Undergraduate student"}},"ChoiceOrder":[1,2,"5","6",3,"7","8",4],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":9,"NextAnswerId":1,"QuestionID":"QID34","DataVisibility":{"Private":false,"Hidden":false},"GradingData":[],"QuestionText_Unsafe":"In your institution, what is your role\/status?"}},{"SurveyID":"SV_5ArtYnx6kWMXYNv","Element":"SQ","PrimaryAttribute":"QID1","SecondaryAttribute":"Informed Consent By submitting to this form, you are agreeing to allow us to use this data for ou...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div>Informed Consent<\/div><div>By submitting to this form, you are agreeing to allow us to use this data for our research. Filling this out implies consent. The data will be confidential and shared openly and freely with participants. We are interested in publishing the results to help archives advocate for more resources. <br><\/div><div><br><\/div>","DataExportTag":"Q1","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Informed Consent By submitting to this form, you are agreeing to allow us to use this data for ou...","Choices":{"1":{"Display":""},"2":{"Display":"Click to write Choice 2"},"3":{"Display":"Click to write Choice 3"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"OFF","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID1","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_5ArtYnx6kWMXYNv","Element":"SQ","PrimaryAttribute":"QID46","SecondaryAttribute":"Informed Consent for Investigating & Archiving the Scholarly Git Experience \u00a0 You have been invit..","TertiaryAttribute":null,"Payload":{"QuestionText":"<p>Informed Consent for <em>Investigating &amp; Archiving the Scholarly Git Experience<\/em><\/p>\n\n<p>&nbsp;<\/p>\n\n<p>You have been invited to take part in a research study to learn more about how people in academia interact with version control, specifically Git, and source code hosting platforms (e.g. GitLab, SourceForge, GitHub). This study will be conducted by Vicky Steeves and Sarah Nguyen of NYU Division of Libraries.<\/p>\n&nbsp;\n\n<p>If you agree to be in this study, you will be asked to complete a 30 question survey about version control and source code hosting. It will take approximately 10 minutes to finish this survey. There are no known risks associated with your participation in this research beyond those of everyday life.<\/p>\n&nbsp;\n\n<p>Although you will receive no direct benefits, this research may help the investigators understand how people in academia interact with version control, specifically Git, and source code hosting platforms (e.g. GitLab, SourceForge, GitHub), and so help in efforts to teach version control, as well as preserve source code.<\/p>\n&nbsp;\n\n<p>Confidentiality of your research records will be strictly maintained by not asking you for any individually identifiable information. We may ask for broader demographics but never in such a way that it can be used, even in conjunction with other questions, to individually identify you. If you put something identifying in the free text answers of this survey, we will lightly modify them to protect your identity when publishing the data. Your information from this study will not be used for future research.<\/p>\n&nbsp;\n\n<p>Participation in this study is voluntary. You may refuse to participate or withdraw at any time without penalty.&nbsp;<\/p>\n&nbsp;\n\n<p>If there is anything about the study or your participation that is unclear or that you do not understand, if you have questions or wish to report a research-related problem, you may contact Vicky Steeves at (212) 992-6269 or vs77@nyu.edu.<\/p>\n&nbsp;\n\n<p>For questions about your rights as a research participant, you may contact the University Committee on Activities Involving Human Subjects (UCAIHS), New York University, 665 Broadway, Suite 804, New York, New York, 10012, at ask.humansubjects@nyu.edu or (212) 998-4808. Please reference the study IRB-FY2019-3399 when contacting the IRB (UCAIHS).<\/p>\n&nbsp;\n\n<p>You may print this page for your records.<\/p>","DefaultChoices":false,"DataExportTag":"Q1","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Informed Consent for Investigating & Archiving the Scholarly Git Experience \u00a0 You have been invit...","Choices":{"1":{"Display":"I understand and wish to continue."},"2":{"Display":"I do not want to take part in this study."}},"ChoiceOrder":[1,2],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":3,"NextAnswerId":1,"QuestionID":"QID46","DataVisibility":{"Private":false,"Hidden":false},"QuestionText_Unsafe":"<p>Informed Consent for <em>Investigating &amp; Archiving the Scholarly Git Experience<\/em><\/p>\n\n<p>&nbsp;<\/p>\n\n<p>You have been invited to take part in a research study to learn more about how people in academia interact with version control, specifically Git, and source code hosting platforms (e.g. GitLab, SourceForge, GitHub). This study will be conducted by Vicky Steeves and Sarah Nguyen of NYU Division of Libraries.<\/p>\n&nbsp;\n\n<p>If you agree to be in this study, you will be asked to complete a 30 question survey about version control and source code hosting. It will take approximately 10 minutes to finish this survey. There are no known risks associated with your participation in this research beyond those of everyday life.<\/p>\n&nbsp;\n\n<p>Although you will receive no direct benefits, this research may help the investigators understand how people in academia interact with version control, specifically Git, and source code hosting platforms (e.g. GitLab, SourceForge, GitHub), and so help in efforts to teach version control, as well as preserve source code.<\/p>\n&nbsp;\n\n<p>Confidentiality of your research records will be strictly maintained by not asking you for any individually identifiable information. We may ask for broader demographics but never in such a way that it can be used, even in conjunction with other questions, to individually identify you. If you put something identifying in the free text answers of this survey, we will lightly modify them to protect your identity when publishing the data. Your information from this study will not be used for future research.<\/p>\n&nbsp;\n\n<p>Participation in this study is voluntary. You may refuse to participate or withdraw at any time without penalty.&nbsp;<\/p>\n&nbsp;\n\n<p>If there is anything about the study or your participation that is unclear or that you do not understand, if you have questions or wish to report a research-related problem, you may contact Vicky Steeves at (212) 992-6269 or vs77@nyu.edu.<\/p>\n&nbsp;\n\n<p>For questions about your rights as a research participant, you may contact the University Committee on Activities Involving Human Subjects (UCAIHS), New York University, 665 Broadway, Suite 804, New York, New York, 10012, at ask.humansubjects@nyu.edu or (212) 998-4808. Please reference the study IRB-FY2019-3399 when contacting the IRB (UCAIHS).<\/p>\n&nbsp;\n\n<p>You may print this page for your records.<\/p>"}},{"SurveyID":"SV_5ArtYnx6kWMXYNv","Element":"SQ","PrimaryAttribute":"QID37","SecondaryAttribute":"Informed Consent: placeholder for IRB mandated form","TertiaryAttribute":null,"Payload":{"QuestionText":"<strong>Informed Consent: <\/strong>placeholder for IRB mandated form","DefaultChoices":false,"DataExportTag":"Q1","QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Informed Consent: placeholder for IRB mandated form","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID37","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_5ArtYnx6kWMXYNv","Element":"SQ","PrimaryAttribute":"QID11","SecondaryAttribute":"Insert your email address below, if you are interested in participating in an one-on-one intervie...","TertiaryAttribute":null,"Payload":{"QuestionText":"<p dir=\"ltr\" style=\"list-style-type:decimal;font-size:11pt;font-family:Avenir,sans-serif;color:#000000;background-color:transparent;font-weight:400;font-style:normal;font-variant:normal;text-decoration:none;vertical-align:baseline;white-space:pre;line-height:2.4;margin-top:0pt;margin-bottom:0pt;\"><span style=\"font-size:11pt;font-family:Avenir,sans-serif;color:#000000;background-color:transparent;font-weight:400;font-style:normal;font-variant:normal;text-decoration:none;vertical-align:baseline;white-space:pre;white-space:pre-wrap;\">Insert your email address below, if you are interested in participating in an one-on-one interview for the qualitative portion of our research.<\/span><\/p>","DefaultChoices":false,"DataExportTag":"Q30","QuestionID":"QID11","QuestionType":"TE","Selector":"SL","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","AllowFreeResponse":"false"},"QuestionDescription":"Insert your email address below, if you are interested in participating in an one-on-one intervie...","Validation":{"Settings":{"ForceResponse":"OFF","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1}},{"SurveyID":"SV_5ArtYnx6kWMXYNv","Element":"SQ","PrimaryAttribute":"QID55","SecondaryAttribute":"Part 1: Background Information Let\u2019s start with some basic information about you, code, and versi.","TertiaryAttribute":null,"Payload":{"QuestionText":"<p>Part 1: Background Information<\/p><p><br><\/p>Let\u2019s start with some basic information about you, code, and version control systems.","DefaultChoices":false,"DataExportTag":"Q2","QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Part 1: Background Information Let\u2019s start with some basic information about you, code, and versi...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID55","QuestionText_Unsafe":"<p>Part 1: Background Information<\/p><p><br><\/p>Let\u2019s start with some basic information about you, code, and version control systems.","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_5ArtYnx6kWMXYNv","Element":"SQ","PrimaryAttribute":"QID79","SecondaryAttribute":"Part 2: Learning Git Now, let\u2019s think about how you first started to learn and use git on your lo.","TertiaryAttribute":null,"Payload":{"QuestionText":"Part 2: Learning Git <br><div><br><\/div><div>Now, let\u2019s think about how you first started to learn and use git on your local computer (e.g. not on github.com or gitlab.com).<br><\/div>","DefaultChoices":false,"DataExportTag":"Q15","QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Part 2: Learning Git Now, let\u2019s think about how you first started to learn and use git on your lo...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID79","QuestionText_Unsafe":"Part 2: Learning Git <br><div><br><\/div><div>Now, let\u2019s think about how you first started to learn and use git.<\/div>","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_5ArtYnx6kWMXYNv","Element":"SQ","PrimaryAttribute":"QID82","SecondaryAttribute":"Part 3: Teaching Git In this section, we will ask a few questions about teaching git and your met...","TertiaryAttribute":null,"Payload":{"QuestionText":"Part 3: Teaching Git <br><div><br><\/div><div>In this section, we will ask a few questions about teaching git and your methods (if you teach it!).<br><\/div>","DefaultChoices":false,"DataExportTag":"Q25","QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Part 3: Teaching Git In this section, we will ask a few questions about teaching git and your met...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID82","QuestionText_Unsafe":"Part 3: Teaching Git <br><div><br><\/div><div>In this section, we will discuss teaching git to others.<\/div>","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_5ArtYnx6kWMXYNv","Element":"SQ","PrimaryAttribute":"QID84","SecondaryAttribute":"Part 4: Hosting Platform Now, we\u2019ll cover how you use source code hosting platforms.","TertiaryAttribute":null,"Payload":{"QuestionText":"Part 4: Hosting Platform<br><div><br><\/div><div>Now, we\u2019ll cover how you use source code hosting platforms.<\/div>","DefaultChoices":false,"DataExportTag":"Q31","QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Part 4: Hosting Platform Now, we\u2019ll cover how you use source code hosting platforms.","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID84","QuestionText_Unsafe":"Part 4: Hosting Platform<br><div><br><\/div><div>Now, we\u2019ll cover how you use (or not use) git hosting platforms.<\/div>","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_5ArtYnx6kWMXYNv","Element":"SQ","PrimaryAttribute":"QID85","SecondaryAttribute":"Part 5: Scholarship In this section, we'll ask a few questions about your scholarship and workflow.","TertiaryAttribute":null,"Payload":{"QuestionText":"Part 5: Scholarship<br><div><br><\/div><div>In this section, we'll ask a few questions about your scholarship and workflow.<br><\/div>","DefaultChoices":false,"DataExportTag":"Q36","QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Part 5: Scholarship In this section, we'll ask a few questions about your scholarship and workflow.","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID85","QuestionText_Unsafe":"Part 5: Scholarship<br><div><br><\/div><div>In this section, let\u2019s discuss your personal research or scholarship in relation to git.<\/div>","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_5ArtYnx6kWMXYNv","Element":"SQ","PrimaryAttribute":"QID88","SecondaryAttribute":"Part 6: Sustainability Now we\u2019re going to talk about the longevity and preservation of your work..","TertiaryAttribute":null,"Payload":{"QuestionText":"Part 6: Sustainability<br><div><br><\/div><div>Now we\u2019re going to talk about the longevity and preservation of your work with git and code hosting platforms.<\/div>","DefaultChoices":false,"DataExportTag":"Q46","QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Part 6: Sustainability Now we\u2019re going to talk about the longevity and preservation of your work...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID88","QuestionText_Unsafe":"Part 6: Sustainability<br><div><br><\/div><div>Now we\u2019re going to talk about the longevity and preservation of your work with git and git hosting platforms.<\/div>","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_5ArtYnx6kWMXYNv","Element":"SQ","PrimaryAttribute":"QID89","SecondaryAttribute":"Part 7: Demographics This section will ask some very high-level demographic questions about you t...","TertiaryAttribute":null,"Payload":{"QuestionText":"Part 7: Demographics<br><div><br><\/div><div>This section will ask some very high-level demographic questions about you to help guide our recommendations and analysis.<br><\/div>","DefaultChoices":false,"DataExportTag":"Q49","QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Part 7: Demographics This section will ask some very high-level demographic questions about you t...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID89","QuestionText_Unsafe":"Part 7: Demographics<br><div><br><\/div><div>This section will focus on you and your profession.<\/div>","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_5ArtYnx6kWMXYNv","Element":"SQ","PrimaryAttribute":"QID38","SecondaryAttribute":"Please provide a URL to funding agency project or grant #","TertiaryAttribute":null,"Payload":{"QuestionText":"Please provide a URL to funding agency project or grant #","DefaultChoices":false,"DataExportTag":"Q11","QuestionType":"TE","Selector":"SL","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please provide a URL to funding agency project or grant #","Validation":{"Settings":{"ForceResponse":"OFF","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionID":"QID38","DataVisibility":{"Private":false,"Hidden":false},"QuestionText_Unsafe":"Please provide a URL to funding agency project or grant #"}},{"SurveyID":"SV_5ArtYnx6kWMXYNv","Element":"SQ","PrimaryAttribute":"QID86","SecondaryAttribute":"Please provide a URL to the funded project","TertiaryAttribute":null,"Payload":{"QuestionText":"Please provide a URL to the funded project","DefaultChoices":false,"DataExportTag":"Q39","QuestionType":"TE","Selector":"SL","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please provide a URL to the funded project","Validation":{"Settings":{"ForceResponse":"OFF","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionID":"QID86","QuestionText_Unsafe":"Please provide a URL to funding agency project or grant #.","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_5ArtYnx6kWMXYNv","Element":"SQ","PrimaryAttribute":"QID20","SecondaryAttribute":"What are your favorite resources on how to use git?","TertiaryAttribute":null,"Payload":{"QuestionText":"What are your favorite resources on how to use git?","DefaultChoices":false,"DataExportTag":"Q21","QuestionType":"TE","Selector":"ML","Configuration":{"QuestionDescriptionOption":"UseText","AllowFreeResponse":"false"},"QuestionDescription":"What are your favorite resources on how to use git?","Validation":{"Settings":{"ForceResponse":"OFF","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID20","DataVisibility":{"Private":false,"Hidden":false},"SearchSource":{"AllowFreeResponse":"false"},"QuestionText_Unsafe":"What are your favorite resources on how to use git?"}},{"SurveyID":"SV_5ArtYnx6kWMXYNv","Element":"SQ","PrimaryAttribute":"QID62","SecondaryAttribute":"What is the primary reason you use git hosting platforms?","TertiaryAttribute":null,"Payload":{"QuestionText":"What is the primary reason you use git hosting platforms?","DataExportTag":"Q32","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"What is the primary reason you use git hosting platforms?","Choices":{"1":{"Display":"Openness (e.g. sharing data and code for open access)"},"2":{"Display":"Method tracking (e.g. documenting methodologies and protocols)"},"3":{"Display":"Change tracking (e.g. changes\/additions to code on a macro-scale)"},"4":{"Display":"Publishing (e.g. making content available online)"},"5":{"Display":"Version Control"},"6":{"Display":"Collaboration (e.g. editing and updating data\/code within a team)"},"7":{"Display":"Other:","TextEntry":"true"}},"ChoiceOrder":["1","2","3","4","5","6","7"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":9,"NextAnswerId":1,"QuestionID":"QID62","QuestionText_Unsafe":"What is the primary reason you use git hosting platforms?","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_5ArtYnx6kWMXYNv","Element":"SQ","PrimaryAttribute":"QID35","SecondaryAttribute":"What is your academic discipline?","TertiaryAttribute":null,"Payload":{"QuestionText":"What is your academic discipline?","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\t\/*Place your JavaScript here to run when the page loads*\/\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\/*Place your JavaScript here to run when the page is fully displayed*\/\n\tjQuery(\"#\"+this.questionId+\" select\").select2({ placeholder:\"Select an option\" });\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","DefaultChoices":false,"DataExportTag":"Q50","QuestionID":"QID35","QuestionType":"MC","Selector":"DL","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"What is your academic discipline?","Choices":{"1":{"Display":"Accounting & Finance "},"2":{"Display":"Acoustics  "},"3":{"Display":"Actuarial Science"},"4":{"Display":"Addiction Prevention & Treatment "},"5":{"Display":"Advertising "},"6":{"Display":"Astronautical Engineering "},"7":{"Display":"Aeronautics-Aviation-Aerospace"},"8":{"Display":"Aerospace Medicine "},"9":{"Display":"Aerospace Aeronautical & Engineering "},"10":{"Display":"Aesthetician-Esthetician & Skin Care"},"11":{"Display":"African Studies"},"12":{"Display":"African-American-Black Studies "},"13":{"Display":"Agribusiness-Agricultural Business Operations "},"14":{"Display":"Agricultural & Domestic Animals Services  "},"15":{"Display":"Agricultural & Food Products Processing "},"16":{"Display":"Agricultural & Horticultural"},"17":{"Display":"Agricultural Animal Breeding "},"18":{"Display":"Agricultural Sciences "},"19":{"Display":"Agriculture Operations"},"20":{"Display":