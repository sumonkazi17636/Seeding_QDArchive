our own?","TertiaryAttribute":null,"Payload":{"QuestionText":"How do you document your research protocols, either as a part of a group or on your own?","DefaultChoices":false,"DataExportTag":"Q44","QuestionID":"QID70","QuestionType":"TE","Selector":"ML","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"How do you document your research protocols, either as a part of a group or on your own?","Validation":{"Settings":{"ForceResponse":"OFF","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionText_Unsafe":"How do you document your research protocols, either as a part of a group or on your own?","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_5ArtYnx6kWMXYNv","Element":"SQ","PrimaryAttribute":"QID59","SecondaryAttribute":"How do you generate materials for these teaching sessions?","TertiaryAttribute":null,"Payload":{"QuestionText":"How do you generate materials for these teaching sessions?","DataExportTag":"Q27","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"How do you generate materials for these teaching sessions?","Choices":{"1":{"Display":"I make them myself"},"2":{"Display":"I reuse materials from others"},"3":{"Display":"I mix original and secondary materials"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID59","QuestionText_Unsafe":"How do you generate materials for these teaching sessions?","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_5ArtYnx6kWMXYNv","Element":"SQ","PrimaryAttribute":"QID44","SecondaryAttribute":"How do you onboard, off-board, and record\/gather documentation for your lab\/research group protoc...","TertiaryAttribute":null,"Payload":{"QuestionText":"How do you onboard, off-board, and record\/gather documentation for your lab\/research group protocols?","DefaultChoices":false,"DataExportTag":"Q8","QuestionType":"TE","Selector":"SL","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"How do you onboard, off-board, and record\/gather documentation for your lab\/research group protoc...","Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionID":"QID44","DataVisibility":{"Private":false,"Hidden":false},"QuestionText_Unsafe":"How do you onboard, off-board, and record\/gather documentation for your lab\/research group protocols?"}},{"SurveyID":"SV_5ArtYnx6kWMXYNv","Element":"SQ","PrimaryAttribute":"QID76","SecondaryAttribute":"How do you primarily interact with git on your local computer? Check all that apply.","TertiaryAttribute":null,"Payload":{"QuestionText":"How do you primarily interact with git on your local computer? Check all that apply.","DataExportTag":"Q14","QuestionType":"MC","Selector":"MAVR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"How do you primarily interact with git on your local computer? Check all that apply.","Choices":{"1":{"Display":"Graphical user interface (e.g.GitKraken, GitHub Desktop, etc.)"},"2":{"Display":"Terminal"},"3":{"Display":"Other:","TextEntry":"true"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"OFF","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID76","QuestionText_Unsafe":"How do you primarily interact with git on your local computer? Check all that apply.","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_5ArtYnx6kWMXYNv","Element":"SQ","PrimaryAttribute":"QID24","SecondaryAttribute":"How do you tend to use git primarily? Check all that apply.","TertiaryAttribute":null,"Payload":{"QuestionText":"How do you tend to use git primarily? Check all that apply.","DataExportTag":"Q26","QuestionType":"MC","Selector":"MAVR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"How do you tend to use git primarily? Check all that apply.","Choices":{"1":{"Display":"Openness (e.g. sharing data and code for open access)"},"2":{"Display":"Method tracking (e.g. documenting methodologies and protocols)"},"3":{"Display":"Versioning (e.g. as a version control system)"},"4":{"Display":"Publishing (e.g. making content available online)"},"5":{"Display":"Other","TextEntry":"true"}},"ChoiceOrder":[2,1,4,3,5],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":6,"NextAnswerId":1,"QuestionID":"QID24","DataVisibility":{"Private":false,"Hidden":false},"QuestionText_Unsafe":"How do you tend to use git primarily? Check all that apply."}},{"SurveyID":"SV_5ArtYnx6kWMXYNv","Element":"SQ","PrimaryAttribute":"QID58","SecondaryAttribute":"How frequently do you have to reteach yourself git?","TertiaryAttribute":null,"Payload":{"QuestionText":"<p>How frequently do you have to reteach yourself git?<\/p>","DataExportTag":"Q23","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"How frequently do you have to reteach yourself git?","Choices":{"1":{"Display":"Daily"},"2":{"Display":"Weekly"},"3":{"Display":"Once a semester"},"4":{"Display":"Once a year"},"5":{"Display":"Never"},"6":{"Display":"Other:","TextEntry":"true"}},"ChoiceOrder":["1","2","3","4","5","6"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":7,"NextAnswerId":1,"QuestionID":"QID58","QuestionText_Unsafe":"<p>How frequently do you have to reteach yourself git?<\/p>","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_5ArtYnx6kWMXYNv","Element":"SQ","PrimaryAttribute":"QID32","SecondaryAttribute":"How have you engaged in scholarly activity on a git hosting platform? Check all that apply.","TertiaryAttribute":null,"Payload":{"QuestionText":"How have you engaged in scholarly activity on a git hosting platform? Check all that apply.","DataExportTag":"Q40","QuestionType":"MC","Selector":"MAVR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"How have you engaged in scholarly activity on a git hosting platform? Check all that apply.","Choices":{"1":{"Display":"Community & collaboration"},"2":{"Display":"Education"},"3":{"Display":"Method tracking"},"4":{"Display":"Peer production"},"5":{"Display":"Peer review (e.g. using platforms like GitLab, GitHub, etc. to review source code or articles. Journals such as <a href=\"https:\/\/joss.theoj.org\/\" target=\"_blank\">JOSS<\/a>)"},"6":{"Display":"Publishing scholarship"},"7":{"Display":"Quality assurance"},"8":{"Display":"Reproducibility"},"10":{"Display":"Other","TextEntry":"true"}},"ChoiceOrder":[1,2,"3","4","5","6","7","8","10"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":11,"NextAnswerId":1,"QuestionID":"QID32","DataVisibility":{"Private":false,"Hidden":false},"QuestionText_Unsafe":"How have you engaged in scholarly activity on a git hosting platform? Check all that apply."}},{"SurveyID":"SV_5ArtYnx6kWMXYNv","Element":"SQ","PrimaryAttribute":"QID13","SecondaryAttribute":"How is your research funded?","TertiaryAttribute":null,"Payload":{"QuestionText":"How is your research funded?","DataExportTag":"Q9","QuestionType":"MC","Selector":"MAVR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"How is your research funded?","Choices":{"1":{"Display":"Private institution (industry, individual, etc.)"},"2":{"Display":"Public (Federal, government, research councils, etc.)"},"3":{"Display":"I don\u2019t know"}},"ChoiceOrder":[1,2,3],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":5,"NextAnswerId":1,"QuestionID":"QID13","DataVisibility":{"Private":false,"Hidden":false},"GradingData":[],"QuestionText_Unsafe":"How is your research funded?"}},{"SurveyID":"SV_5ArtYnx6kWMXYNv","Element":"SQ","PrimaryAttribute":"QID66","SecondaryAttribute":"How is your research or scholarship funded? Check all that apply.","TertiaryAttribute":null,"Payload":{"QuestionText":"How is your research or scholarship funded? Check all that apply.","DataExportTag":"Q37","QuestionType":"MC","Selector":"MAVR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"How is your research or scholarship funded? Check all that apply.","Choices":{"1":{"Display":"Privately (e.g. industry, philanthropic organizations)"},"2":{"Display":"Publicly (e.g. federal government)"},"4":{"Display":"I don't know"},"5":{"Display":"Other:","TextEntry":"true"},"6":{"Display":"I don't have funded research right now"}},"ChoiceOrder":["1","2","4","6","5"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":7,"NextAnswerId":1,"QuestionID":"QID66","QuestionText_Unsafe":"How is your research or scholarship funded?","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_5ArtYnx6kWMXYNv","Element":"SQ","PrimaryAttribute":"QID5","SecondaryAttribute":"How long have you been using Git in your workflow?","TertiaryAttribute":null,"Payload":{"QuestionText":"How long have you been using Git in your workflow?","DataExportTag":"Q5","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"How long have you been using Git in your workflow?","Choices":{"1":{"Display":"Click to write Choice 1"},"2":{"Display":"Click to write Choice 2"},"3":{"Disp